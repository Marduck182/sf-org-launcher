{
  "compilerOptions": {
    "composite":       true,
    "moduleResolution": "bundler",
    "module":          "ESNext",
    "target":          "ES2022",
    "lib":             ["ES2022"],
    "strict":          true,
    "skipLibCheck":    true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl":         ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ]
}
